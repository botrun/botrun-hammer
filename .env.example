# Botrun Whisper 設定範例 / Configuration Example
# 複製此檔案為 .env 並填入你的 API Key
# Copy this file to .env and fill in your API keys
#
# Gemini 是主要 API / Gemini is the primary API
# NCHC 是備用 API / NCHC is the backup API

# Gemini API Key（主要 / Primary）
# 申請網址 / Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=你的Gemini_API_Key

# NCHC GenAI API Key（備用 / Backup）
# 申請網址 / Get key: https://portal.genai.nchc.org.tw/
NCHC_GENAI_API_KEY=你的NCHC_API_Key
